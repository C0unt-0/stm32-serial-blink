{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug STM32F407VG (OpenOCD)",
      "type": "cortex-debug",
      "request": "launch",

      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/firmware.elf",

      "servertype": "openocd",
      "serverpath": "/opt/homebrew/bin/openocd",
      "device": "STM32F407VG",

      "configFiles": ["interface/stlink.cfg", "target/stm32f4x.cfg"],

      "preLaunchTask": "build",
      "runToEntryPoint": "main",

      "svdFile": "Keil::STM32F4xx_DFP@3.1.1",
      "deviceName": "STM32F407VETx",
      "showDevDebugOutput": "none",

      "liveWatch": {
        "enabled": true,
        "samplesPerSecond": 4
      }
    }
  ]
}
