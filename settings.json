{
  "cortex-debug.armToolchainPath": "/opt/ST/STM32CubeCLT_1.22.0/GNU-tools-for-STM32/bin",
  "cortex-debug.gdbPath": "/opt/ST/STM32CubeCLT_1.22.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb",

  "makefile.launchConfigurations": [
    {
      "cwd": "${workspaceFolder}",
      "binaryPath": "${workspaceFolder}/firmware.elf",
      "binaryArgs": []
    }
  ],

  "makefile.extensionOutputFolder": "${workspaceFolder}/.vscode",

  "C_Cpp.default.compilerPath": "/opt/ST/STM32CubeCLT_1.22.0/GNU-tools-for-STM32/bin/arm-none-eabi-g++",
  "C_Cpp.default.cppStandard": "c++17",
  "C_Cpp.default.cStandard": "c11",
  "C_Cpp.default.intelliSenseMode": "gcc-arm",

  "files.associations": {
    "*.h": "cpp",
    "*.hpp": "cpp",
    "*.cpp": "cpp",
    "*.tpp": "cpp"
  },

  "cortex-debug.variableUseNaturalFormat": true
