{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "make",
      "args": ["all"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$gcc"
    },
    {
      "label": "test",
      "type": "shell",
      "command": "make",
      "args": ["test"],
      "problemMatcher": "$gcc"
    },
    {
      "label": "flash",
      "type": "shell",
      "command": "make",
      "args": ["flash"],
      "dependsOn": ["build"]
    },
    {
      "label": "clean",
      "type": "shell",
      "command": "make",
      "args": ["clean"]
    }
  ]
}
